{{! Rendered by AnimationSettingsForm. The root <form> is the Application element itself
    (DEFAULT_OPTIONS.tag), so this part must not declare a <form> of its own. }}
<div class="wod-settings-body">

  <div class="form-group">
    <label>{{settings.animationMode.name}}</label>
    <div class="form-fields">
      <select name="animationMode">
        {{selectOptions settings.animationMode.choices selected=settings.animationMode.value}}
      </select>
    </div>
    <p class="hint">{{settings.animationMode.hint}}</p>
  </div>

  <div class="form-group">
    <label>{{settings.rouletteDelay.name}}</label>
    <div class="form-fields">
      <range-picker name="rouletteDelay" value="{{settings.rouletteDelay.value}}"
                    min="{{settings.rouletteDelay.range.min}}"
                    max="{{settings.rouletteDelay.range.max}}"
                    step="{{settings.rouletteDelay.range.step}}"></range-picker>
    </div>
    <p class="hint">{{settings.rouletteDelay.hint}}</p>
  </div>

  <div class="form-group">
    <label>{{settings.rouletteTotalDuration.name}}</label>
    <div class="form-fields">
      <range-picker name="rouletteTotalDuration" value="{{settings.rouletteTotalDuration.value}}"
                    min="{{settings.rouletteTotalDuration.range.min}}"
                    max="{{settings.rouletteTotalDuration.range.max}}"
                    step="{{settings.rouletteTotalDuration.range.step}}"></range-picker>
    </div>
    <p class="hint">{{settings.rouletteTotalDuration.hint}}</p>
  </div>


  <div class="form-group">
    <label>{{settings.panToToken.name}}</label>
    <div class="form-fields">
      <input type="checkbox" name="panToToken" data-dtype="Boolean" {{checked settings.panToToken.value}}>
    </div>
    <p class="hint">{{settings.panToToken.hint}}</p>
  </div>

  <div class="form-group">
    <label>{{settings.displaySelected.name}}</label>
    <div class="form-fields">
      <input type="checkbox" name="displaySelected" data-dtype="Boolean" {{checked settings.displaySelected.value}}>
    </div>
    <p class="hint">{{settings.displaySelected.hint}}</p>
  </div>

  <div class="form-group">
    <label>{{settings.imageSource.name}}</label>
    <div class="form-fields">
      <select name="imageSource">
        {{selectOptions settings.imageSource.choices selected=settings.imageSource.value}}
      </select>
    </div>
    <p class="hint">{{settings.imageSource.hint}}</p>
  </div>

  <footer class="wod-settings-footer">
    <button type="submit">
      <i class="fas fa-save"></i> Save Changes
    </button>
  </footer>

</div>
